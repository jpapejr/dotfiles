{
  "agent_servers": {
    "cline": {
      "type": "registry"
    }
  },
  "icon_theme": "Catppuccin Macchiato",
  "agent": {
    "profiles": {
      
    },
    "inline_assistant_model": {
      "provider": "IBM Consulting Advantage",
      "model": "global/anthropic.claude-sonnet-4-5-20250929-v1:0",
      "enable_thinking": false
    },
    "default_model": {
      "provider": "IBM Consulting Advantage",
      "model": "global/anthropic.claude-sonnet-4-5-20250929-v1:0",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "context_servers": {
    "mcpact": {
      "enabled": true,
      "remote": false,
      "command": "node",
      "args": [
        "/Users/jtp/Downloads/GitHub/mcpact/dist/src/index.js",
        "--config",
        "/Users/jtp/Downloads/GitHub/mcpact/mcpact.config.json",
      ],
      "env": {},
    },
  },
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
  "language_models": {
    "openai_compatible": {
      "IBM Consulting Advantage": {
        "api_url": "https://servicesessentials.ibm.com/apis/v3",
        "available_models": [
          {
            "name": "global/anthropic.claude-sonnet-4-5-20250929-v1:0",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
  },
  "tabs": {
    "close_position": "left",
  },
  "restore_on_startup": "none",
